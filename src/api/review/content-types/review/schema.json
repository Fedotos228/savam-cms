{
  "kind": "collectionType",
  "collectionName": "reviews",
  "info": {
    "singularName": "review",
    "pluralName": "reviews",
    "displayName": "Review"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "stars": {
      "type": "integer",
      "default": 1,
      "min": 1,
      "max": 5
    },
    "date": {
      "type": "date"
    },
    "content": {
      "type": "blocks"
    },
    "name": {
      "type": "text"
    },
    "avatar": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    }
  }
}
